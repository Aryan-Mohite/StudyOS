# StudyOS Frontend — copy this to .env.local

# -- Auth (Clerk) -----------------------------------------------------------------
# Get these from https://dashboard.clerk.com → your app → API Keys
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_your-key-here
CLERK_SECRET_KEY=sk_test_your-key-here
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_SIGN_IN_FALLBACK_REDIRECT_URL=/dashboard
NEXT_PUBLIC_CLERK_SIGN_UP_FALLBACK_REDIRECT_URL=/dashboard

# -- Database (server-side only, used by src/lib/db.ts) -------------------------
# MySQL connection string. Works with PlanetScale, Railway, Aiven, or local MySQL.
# Example: mysql://user:password@host:3306/studyos
DATABASE_URL=mysql://root:Abs209@6@localhost:3306/studyos

# -- AgenticService (server-side only, used by src/lib/agentic.ts) --------------
# Internal URL of the Python AI service. Never exposed to the browser --
# only Next.js Route Handlers call this, so it does NOT need NEXT_PUBLIC_.
AGENTIC_SERVICE_URL=http://localhost:8000

# -- Frontend behavior ------------------------------------------------------------
# Flip to true to use the real API routes instead of mock data
NEXT_PUBLIC_USE_REAL_API=true

# Only set this if the API routes are ever split into a separately-deployed
# service. Leave unset to call same-origin /api/* (the default, recommended).
# NEXT_PUBLIC_API_URL=
