# ── StudyOS Frontend — Environment Variables ─────────────────────────────────
# Copy to .env.local and edit. Never commit .env.local to git.

# Phase 2: set to true to enable real API calls for Notes + Upload.
# Leave false (or unset) to use mock data for all features.
NEXT_PUBLIC_USE_REAL_API=false

# Phase 2: URL of the FastAPI backend (must match the uvicorn port).
NEXT_PUBLIC_API_URL=http://localhost:8000

# Phase 4: Clerk auth keys (leave empty until Phase 4).
# NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
# CLERK_SECRET_KEY=sk_test_...
