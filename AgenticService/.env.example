# Python AgenticService config
ANTHROPIC_API_KEY=sk-ant-...

# Port this service listens on. Railway/Render set PORT automatically in prod;
# this default is just for local dev.
PORT=8000

# Comma-separated list of origins allowed to call this service.
# Dev: Next.js running locally. Prod: your Vercel deployment URL.
ALLOWED_ORIGINS=http://localhost:3000,https://your-app.vercel.app
