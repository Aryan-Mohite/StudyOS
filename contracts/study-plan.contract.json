{
  "$schema": "StudyOS/contracts/study-plan",
  "description": "Output of the Study Plan Generator. Triggered when user uploads syllabus and sets an exam date.",
  "trigger": {
    "input": {
      "syllabus_id": "string (UUID)",
      "exam_date": "ISO date string (YYYY-MM-DD)",
      "daily_hours_available": "number (default 6)",
      "weak_subjects": ["subject names user has flagged as weak"],
      "completed_topics": ["topic_ids already studied"]
    }
  },
  "contract": {
    "plan_id": "string (UUID)",
    "syllabus_id": "string (UUID)",
    "exam_date": "ISO date string (YYYY-MM-DD)",
    "generated_at": "ISO 8601 datetime string",
    "total_days": "number",
    "total_topics": "number",
    "daily_hours": "number",
    "weeks": [
      {
        "week_number": "number (1-indexed)",
        "theme": "string — describes the focus of this week (e.g. 'Foundations & Core Concepts')",
        "days": [
          {
            "date": "ISO date string (YYYY-MM-DD)",
            "day_label": "string (e.g. 'Day 1 — Monday, June 3')",
            "is_buffer": "boolean — true for revision/rest days",
            "tasks": [
              {
                "task_id": "string (UUID)",
                "topic_id": "string (UUID — links to syllabus topic)",
                "subject": "string",
                "topic": "string",
                "duration_minutes": "number",
                "task_type": "study | revise | practice | mock_test",
                "priority": "high | medium | low",
                "notes": "string | null — specific guidance for this task (e.g. 'Focus on derivations')"
              }
            ]
          }
        ]
      }
    ]
  },
  "example": {
    "plan_id": "sp-001",
    "syllabus_id": "s-001",
    "exam_date": "2024-11-15",
    "generated_at": "2024-10-01T09:00:00Z",
    "total_days": 45,
    "total_topics": 38,
    "daily_hours": 6,
    "weeks": [
      {
        "week_number": 1,
        "theme": "Heat Transfer Foundations",
        "days": [
          {
            "date": "2024-10-01",
            "day_label": "Day 1 — Tuesday, Oct 1",
            "is_buffer": false,
            "tasks": [
              {
                "task_id": "task-001",
                "topic_id": "t-042",
                "subject": "Heat Transfer",
                "topic": "Fourier's Law of Heat Conduction",
                "duration_minutes": 90,
                "task_type": "study",
                "priority": "high",
                "notes": "Focus on deriving the formula and understanding the physical meaning of each term"
              },
              {
                "task_id": "task-002",
                "topic_id": "t-043",
                "subject": "Heat Transfer",
                "topic": "Thermal Resistance",
                "duration_minutes": 60,
                "task_type": "study",
                "priority": "high",
                "notes": null
              }
            ]
          }
        ]
      }
    ]
  },
  "validation_rules": [
    "exam_date must be in the future relative to generated_at",
    "total_days must match actual span from generated_at date to exam_date",
    "every topic_id in tasks must exist in the syllabus",
    "last 3–5 days should have task_type: mock_test or revise only",
    "no single day should exceed daily_hours × 60 minutes in total task duration",
    "at least 1 buffer day per week (is_buffer: true)",
    "weak_subjects should receive ~30% more total duration than other subjects"
  ]
}
