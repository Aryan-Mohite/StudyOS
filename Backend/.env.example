# ── StudyOS Backend — Environment Variables ──────────────────────────────────
# Copy this file to .env and fill in your values.
# Never commit .env to git.

# Required: Anthropic API key (get from https://console.anthropic.com)
ANTHROPIC_API_KEY=sk-ant-...

# Optional: SQLite DB file path (default: studyos.db in the Backend directory)
DB_PATH=studyos.db

# Optional: Max PDF size in MB (default: 10)
MAX_PDF_SIZE_MB=10

# Optional: Allowed CORS origins (comma-separated list, default: localhost:3000)
# CORS_ORIGINS=["http://localhost:3000","http://127.0.0.1:3000"]
